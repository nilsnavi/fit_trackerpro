# Root .gitignore for FitTracker Pro

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (root level)
.env
.env.local
.env.*.local

# Docker
.dockerignore
docker-compose.override.yml

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Local development files
*.local

# Secrets (never commit)
secrets/
*.secret
*.key
*.pem
*.cert

# Database files (root level)
*.db
*.sqlite3

# Misc
.cache/

# Accidental root Node/Prisma artifacts
/node_modules/
/package.json
/package-lock.json
