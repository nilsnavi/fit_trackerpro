# Root .gitignore for FitTracker Pro

# --- IDE / editors ---
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
*.code-workspace

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Environment & secrets ---
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.sentryclirc

# Docker (корневой .dockerignore не коммитим; см. также frontend/.dockerignore)
/.dockerignore
docker-compose.override.yml
docker-compose.override.yaml
*.local.yml
*.local.yaml

# --- SSL / reverse proxy (локальные копии сертификатов на машине разработчика) ---
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt
nginx/logs/
*.csr

# --- Deploy / backups (pg_dump и т.п.; не трогаем *.sql в database/) ---
backups/

# --- Temporary & scratch ---
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
*.local

# --- Secrets (never commit) ---
secrets/
*.secret

# --- Database files ---
*.db
*.sqlite
*.sqlite3
dump.rdb

# --- Python ---
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# только корневой каталог сборок Python (не frontend/**/lib/)
/lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
venv/
.venv/
ENV/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/
.tox/
.hypothesis/
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/
*.cover
.dmypy.json
dmypy.json
.ipynb_checkpoints/
*.prof

# --- Node / JS (monorepo + случайные артефакты в корне) ---
node_modules/
jspm_packages/
web_modules/
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.eslintcache
.stylelintcache
.parcel-cache
.turbo
.vercel
.netlify
.vite
*.tsbuildinfo

# Root package.json используется для монорепо-скриптов (frontend+backend).

# --- Testing / E2E ---
playwright-report/
test-results/
blob-report/
.playwright/
.nyc_output/
*.lcov

# --- Misc caches ---
.cache/
*.pid
*.seed
*.pid.lock
