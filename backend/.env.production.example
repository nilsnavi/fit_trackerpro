# FitTracker Pro Production Environment
# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=production
DEBUG=false

# Database
POSTGRES_USER=fittracker
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=fittracker
DATABASE_URL=postgresql+asyncpg://fittracker:your_secure_password_here@postgres:5432/fittracker
DATABASE_URL_SYNC=postgresql://fittracker:your_secure_password_here@postgres:5432/fittracker

# Redis
REDIS_URL=redis://redis:6379/0
ANALYTICS_CACHE_ENABLED=true
ANALYTICS_CACHE_TTL_SECONDS=120
ANALYTICS_MEMORY_CACHE_ENABLED=true
ANALYTICS_MEMORY_CACHE_TTL_SECONDS=20

# Analytics query limits
ANALYTICS_DEFAULT_MAX_EXERCISES=30
ANALYTICS_MAX_EXERCISES_HARD_LIMIT=100
ANALYTICS_DEFAULT_MAX_DATA_POINTS=120
ANALYTICS_MAX_DATA_POINTS_HARD_LIMIT=365

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBAPP_URL=https://fittrackpro.ru

# Security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_secret_key_here_min_64_chars

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://fittrackpro.ru

# Sentry (optional, for error tracking)
SENTRY_DSN=

# Frontend
VITE_API_URL=https://fittrackpro.ru/api/v1
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
VITE_ENVIRONMENT=production

# GitHub (for CI/CD)
GITHUB_REPOSITORY=your-username/fit_trackerpro
