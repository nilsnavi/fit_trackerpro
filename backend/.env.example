# ==========================================
# FitTracker Pro - Backend Environment
# ==========================================
#
# Empty values are ignored (falls back to code defaults) — safe for optional keys.
#
# Production-critical (override in production; insecure dev defaults exist in code):
#   DATABASE_URL, TELEGRAM_BOT_TOKEN, TELEGRAM_WEBAPP_URL, SECRET_KEY
#
# Optional — all other variables have sensible defaults for local dev / tests.
# ==========================================

# --- Optional: application metadata & runtime mode ---
APP_NAME=FitTracker Pro
APP_VERSION=1.0.0
# Optional: release diagnostics for GET /api/v1/system/version (often set at image build)
GIT_COMMIT_SHA=
BUILD_TIMESTAMP=
ENVIRONMENT=development
DEBUG=true

# --- Production-critical: database (override in prod) ---
# PostgreSQL (asyncpg) example; SQLite dev default is in app.settings.config if unset
DATABASE_URL=postgresql+asyncpg://fittracker:fittracker_password@localhost:5432/fittracker
DATABASE_URL_SYNC=postgresql://fittracker:fittracker_password@localhost:5432/fittracker

# --- Optional: Redis & analytics caching ---
REDIS_URL=redis://localhost:6379/0
ANALYTICS_CACHE_ENABLED=true
ANALYTICS_CACHE_TTL_SECONDS=120
ANALYTICS_MEMORY_CACHE_ENABLED=true
ANALYTICS_MEMORY_CACHE_TTL_SECONDS=20

# Analytics query limits (protect DB from very large responses)
ANALYTICS_DEFAULT_MAX_EXERCISES=30
ANALYTICS_MAX_EXERCISES_HARD_LIMIT=100
ANALYTICS_DEFAULT_MAX_DATA_POINTS=120
ANALYTICS_MAX_DATA_POINTS_HARD_LIMIT=365

# --- Production-critical: Telegram & JWT (override in prod) ---
# Get your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# URL where your Telegram Mini App is hosted
TELEGRAM_WEBAPP_URL=https://fittrackpro.ru
# Generate a strong secret key: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Optional: CORS & observability ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://fittrackpro.ru
SENTRY_DSN=
ENABLE_PROMETHEUS_METRICS=true

# --- Optional: email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# --- Optional: uploads & rate limiting ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
RATE_LIMIT_PER_MINUTE=60

# --- Optional: logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
