# ==========================================
# FitTracker Pro - Backend Environment
# ==========================================

# Application Settings
APP_NAME=FitTracker Pro
APP_VERSION=1.0.0
# Optional: release diagnostics for GET /api/v1/system/version (often set at image build)
GIT_COMMIT_SHA=
BUILD_TIMESTAMP=
ENVIRONMENT=development
DEBUG=true

# Database Configuration
# PostgreSQL connection URLs
DATABASE_URL=postgresql+asyncpg://fittracker:fittracker_password@localhost:5432/fittracker
DATABASE_URL_SYNC=postgresql://fittracker:fittracker_password@localhost:5432/fittracker

# Redis Configuration
# Redis (rate limiting; optional in-memory fallback if unreachable)
REDIS_URL=redis://localhost:6379/0
ANALYTICS_CACHE_ENABLED=true
ANALYTICS_CACHE_TTL_SECONDS=120
ANALYTICS_MEMORY_CACHE_ENABLED=true
ANALYTICS_MEMORY_CACHE_TTL_SECONDS=20

# Analytics query limits (protect DB from very large responses)
ANALYTICS_DEFAULT_MAX_EXERCISES=30
ANALYTICS_MAX_EXERCISES_HARD_LIMIT=100
ANALYTICS_DEFAULT_MAX_DATA_POINTS=120
ANALYTICS_MAX_DATA_POINTS_HARD_LIMIT=365

# Telegram Bot Configuration
# Get your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# URL where your Telegram Mini App is hosted
TELEGRAM_WEBAPP_URL=https://fittrackpro.ru

# Security Settings
# Generate a strong secret key: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://fittrackpro.ru

# Sentry Configuration (optional)
# Error tracking DSN from Sentry
# Release in Sentry is set from GIT_COMMIT_SHA (preferred) or APP_VERSION
SENTRY_DSN=

# Prometheus metrics at /metrics
ENABLE_PROMETHEUS_METRICS=true

# Email Configuration (optional)
# SMTP settings for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# File Storage (optional)
# Path for uploaded files
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Rate Limiting
# Requests per minute
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
