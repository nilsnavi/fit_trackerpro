# Локальный / CI стенд для E2E (docker-compose.e2e.yml). Не используйте в продакшене.
ENVIRONMENT=test
DEBUG=true

# URL для процессов на хосте (Playwright, alembic, seed) — порт см. docker-compose.e2e.yml
TEST_DATABASE_URL=postgresql+asyncpg://e2e:e2e@127.0.0.1:55432/fittracker_e2e
DATABASE_URL=postgresql+asyncpg://e2e:e2e@127.0.0.1:55432/fittracker_e2e
DATABASE_URL_SYNC=postgresql://e2e:e2e@127.0.0.1:55432/fittracker_e2e

REDIS_URL=redis://127.0.0.1:56379/0

TELEGRAM_BOT_TOKEN=test_token_for_e2e
TELEGRAM_WEBAPP_URL=http://127.0.0.1:3000
TELEGRAM_BOT_ENABLED=false

SECRET_KEY=test_secret_key_32_chars_minimum_x

ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:19000,http://localhost:19000
