# ==========================================
# FitTracker Pro — пример .env для ngrok-туннеля
# ==========================================
#
# Скопируйте в корень репозитория как ``.env.ngrok`` и заполните значения.
# Файл ``.env.ngrok`` в .gitignore — не коммитьте токены и пароли.
#
# Значения ниже — заглушки; для бэкенда см. также ``backend/.env.example``.
# ==========================================

TELEGRAM_BOT_TOKEN=PLACEHOLDER
# Сгенерируйте: openssl rand -hex 32
SECRET_KEY=PLACEHOLDER
DATABASE_URL=postgresql+asyncpg://fittracker:fittracker_password@localhost:15432/fittracker
DATABASE_URL_SYNC=postgresql://fittracker:fittracker_password@localhost:15432/fittracker
REDIS_URL=redis://localhost:16379/0
ENVIRONMENT=development
DEBUG=true
# Добавьте публичный HTTPS URL ngrok (и локальные origin при необходимости)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-subdomain.ngrok-free.dev
# Через запятую, без пробелов: 123456789,987654321
ADMIN_USER_IDS=[921766800,224466587]
# Корень Mini App по URL ngrok
TELEGRAM_WEBAPP_URL=https://your-subdomain.ngrok-free.dev

# Dashboard: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=PLACEHOLDER
