{
  "name": "fittracker-pro-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:precommit": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 9999",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "prepare": "node -e \"if(process.env.HUSKY==='0'||process.env.CI){process.exit(0)}\" || husky",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "coverage:baseline:check": "node scripts/coverage-baseline.mjs check",
    "coverage:baseline:update": "node scripts/coverage-baseline.mjs update",
    "api:types:generate": "node scripts/generate-openapi-types.mjs",
    "api:contract:check": "node scripts/check-openapi-types.mjs",
    "e2e": "playwright test",
    "e2e:regression": "playwright test --grep @regression",
    "e2e:workout-flows": "playwright test --grep @workout-flows",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install",
    "e2e:ci": "playwright test --reporter=line,html",
    "e2e:ci:regression": "playwright test --grep @regression --reporter=line,html",
    "e2e:ci:workout-flows": "playwright test --grep @workout-flows --reporter=line,html",
    "e2e:ci:mobile": "playwright test --project=mobile-android --project=mobile-ios --grep @mobile --reporter=line,html",
    "e2e:smoke:real": "playwright test --grep @smoke-real --reporter=line,html",
    "e2e:mvp": "playwright test e2e/mvp-regression.spec.ts",
    "e2e:mvp:headed": "playwright test e2e/mvp-regression.spec.ts --headed",
    "e2e:mvp:stack": "playwright test --project=chromium-mvp-e2e",
    "e2e:golden-path": "playwright test tests/e2e/golden-path.spec.ts --project=chromium-mvp-e2e",
    "e2e:mvp-golden-path:spec": "playwright test e2e/mvp-golden-path.spec.ts --project=chromium"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "^10.49.0",
    "@tanstack/query-sync-storage-persister": "^5.99.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "@telegram-apps/sdk": "^3.11.8",
    "@telegram-apps/sdk-react": "^3.3.9",
    "@tonconnect/ui-react": "^2.4.4",
    "axios": "^1.15.1",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.330.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.2.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "openapi-typescript": "^7.13.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.3",
    "vite": "^8.0.8",
    "vite-plugin-mkcert": "^1.17.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.9"
  }
}
