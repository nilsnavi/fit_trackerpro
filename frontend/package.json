{
  "name": "fittracker-pro-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:precommit": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 9999",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "prepare": "husky install ../.husky",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "coverage:baseline:check": "node scripts/coverage-baseline.mjs check",
    "coverage:baseline:update": "node scripts/coverage-baseline.mjs update",
    "api:types:generate": "node scripts/generate-openapi-types.mjs",
    "api:contract:check": "node scripts/check-openapi-types.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install",
    "e2e:ci": "playwright test --reporter=line,html"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "^8.55.1",
    "@tanstack/query-sync-storage-persister": "^5.95.2",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "@telegram-apps/sdk": "^1.1.3",
    "@telegram-apps/sdk-react": "^1.1.3",
    "@tonconnect/ui-react": "^2.4.4",
    "axios": "^1.14.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.330.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.2.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "openapi-typescript": "^7.13.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-mkcert": "^1.17.3",
    "vite-plugin-pwa": "^1.2.0"
  }
}
