# ==========================================
# FitTracker Pro - Frontend Environment
# ==========================================

# API Configuration (Vite dev / `npm run build` — baked into bundle when set)
VITE_API_URL=http://localhost:8000/api/v1
# Production: https://fittrackpro.ru/api/v1

# Telegram (Vite dev / optional build-time fallback)
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
# Public Mini App URL for deep links (optional in dev)
VITE_TELEGRAM_WEBAPP_URL=

# Docker frontend container: `startup.sh` generates runtime `config.js` from `config.template.js` (envsubst) before nginx — set these on the host / in CI
# API_URL=https://fittrackpro.ru/api/v1
# TELEGRAM_BOT_USERNAME=your_bot_username
# TELEGRAM_WEBAPP_URL=https://t.me/your_bot/your_app

# Environment
# development | production
VITE_ENVIRONMENT=development

# Sentry Configuration (optional)
# Error tracking DSN from Sentry (browser SDK)
VITE_SENTRY_DSN=
# Optional release string for Sentry (e.g. CI commit SHA); defaults to fittracker-web@<package version>
VITE_SENTRY_RELEASE=

# Docker runtime (nginx container) — these are read from `public/config.js` generated at startup.
# Use these when deploying the prebuilt frontend image without rebuilding.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_DIST=

# Feature Flags (optional)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_TOOLS=true
