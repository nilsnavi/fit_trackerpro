# ==========================================
# FitTracker Pro - Frontend Environment
# ==========================================

# API Configuration
# URL of the backend API
VITE_API_URL=http://localhost:8000/api/v1

# Telegram Configuration
# Your Telegram bot username (without @)
VITE_TELEGRAM_BOT_USERNAME=your_bot_username

# Environment
# development | production
VITE_ENVIRONMENT=development

# Sentry Configuration (optional)
# Error tracking DSN from Sentry (browser SDK)
VITE_SENTRY_DSN=
# Optional release string for Sentry (e.g. CI commit SHA); defaults to fittracker-web@<package version>
VITE_SENTRY_RELEASE=

# Feature Flags (optional)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_TOOLS=true
