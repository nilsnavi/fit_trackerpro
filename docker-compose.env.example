# Скопируйте в корень репозитория как `.env` (рядом с docker-compose.yml):
#   PowerShell: Copy-Item docker-compose.env.example .env
# Учётные данные должны совпадать с теми, что в `backend/.env` в строках
# DATABASE_URL / DATABASE_URL_SYNC (пользователь, пароль, имя БД).
#
# Пример: если в backend/.env указано
#   postgresql://fittracker:МОЙ_ПАРОЛЬ@localhost:15432/fittracker
# то здесь:
#   POSTGRES_USER=fittracker
#   POSTGRES_PASSWORD=МОЙ_ПАРОЛЬ
#   POSTGRES_DB=fittracker

POSTGRES_USER=fittracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fittracker
